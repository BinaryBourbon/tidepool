# Injected by Render from the linked postgres instance
DATABASE_URL=postgresql://user:password@host:5432/tidepool

# AoD (Agent on Demand) — coding agent HTTP API
AOD_BASE_URL=https://jake-bagzz.sprites.app
AOD_TOKEN=           # secret — set in Render dashboard only, never commit

# AoD agent to dispatch for coding tasks (v0: general-purpose-engineer ID)
AOD_AGENT_ID=

# GitHub API token (Tidepool-side: branch creation, diff, merge)
GITHUB_TOKEN=

# PostHog API token (funnel metrics + flag control)
POSTHOG_TOKEN=

# Honeycomb API key (error rate + latency signals)
HONEYCOMB_KEY=
